# .env.example — copy to .env for local dev, set these in Railway dashboard for prod

# URL of your deployed desk app on Vercel
BASE_URL=https://your-desk-app.vercel.app

# Optional: lock down which origin can trigger test runs
# Set this to your portfolio site URL in production
ALLOWED_ORIGIN=https://your-portfolio-site.com

# Port (Railway sets this automatically, don't override in prod)
PORT=3001
